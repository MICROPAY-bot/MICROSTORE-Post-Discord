NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/microstore
JWT_SECRET=change_this_secret
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_too
JWT_REFRESH_EXPIRE=30d
APP_NAME=MICROSTORE AUTO POST

# Sprint 4 - Integration with main MICROSTORE Discord bot
# Webhook default jika integrasi tidak mengirim webhookUrl spesifik
INTEGRATION_DEFAULT_WEBHOOK_URL=
# Webhook channel log di server Discord MICROSTORE (opsional, untuk notifikasi status auto-post)
DISCORD_LOG_WEBHOOK_URL=
